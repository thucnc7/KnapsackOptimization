\newcommand{\@sdeptname}{Khoa Toán - Cơ - Tin học}
\newcommand{\csdeptname}[1]{\renewcommand{\@sdeptname}{#1}}

\newcommand{\@tname}{Thesis's title}
\newcommand{\ctname}[1]{\renewcommand{\@tname}{#1}}

\newcommand{\@stuname}{Student 1: Nguyễn Văn An (5...) }
\newcommand{\cstuname}[1]{\renewcommand{\@stuname}{#1}}

\newcommand{\@sMajor}{Khoa học máy tính và thông tin}
\newcommand{\csMajor}[1]{\renewcommand{\@sMajor}{#1}}

\newcommand{\@sProgram}{Standard}
\newcommand{\csProgram}[1]{\renewcommand{\@sProgram}{#1}}
	
\newcommand{\@sSupervise}{Dr. Nguyễn Văn A}
\newcommand{\csSupervise}[1]{\renewcommand{\@sSupervise}{#1}}

\newcommand{\@ttime}{\today}
\newcommand{\cttime}[1]{\renewcommand{\@ttime}{#1}}

\newcommand{\@rname}{Thiết kế và Đánh giá Thuật toán} % report name, luận văn, thực tập...
\newcommand{\crname}[1]{\renewcommand{\@rname}{#1}}

\newsavebox\thesmashminipage
\newenvironment{smashminipage}
  {\begin{lrbox}{\thesmashminipage}\begin{minipage}[t][22cm][t]{\textwidth}}
  {\end{minipage}\end{lrbox}\smash{\usebox{\thesmashminipage}}\clearpage}

\def\coverpage{
\pagestyle{empty}
\begin{smashminipage}
\begin{tikzpicture}[remember picture, overlay]
\draw [line width=1pt]
    ($ (current page.north west) + (2.0cm,-2.0cm) $)
    rectangle
    ($ (current page.south east) + (-1.5cm,1.5cm) $);
\draw [line width=3pt]
    ($ (current page.north west) + (2.15cm,-2.15cm) $)
    rectangle
    ($ (current page.south east) + (-1.65cm,1.65cm) $); 
\end{tikzpicture}

\begin{center}
    {\fontsize{12}{13}\selectfont ĐẠI HỌC QUỐC GIA HÀ NỘI \\}
    {\fontsize{13}{14}\selectfont \textbf{TRƯỜNG ĐẠI HỌC KHOA HỌC TỰ NHIÊN} \\}
    {\fontsize{12}{13}\selectfont \textbf{\MakeUppercase{\@sdeptname}} \\}
    \vspace{0.3cm}
    \rule{6cm}{1pt} \\
    
    \vfill
    
    {\fontsize{14}{16}\selectfont \textbf{BÁO CÁO BÀI TẬP LỚN} \\}
    {\fontsize{13}{14}\selectfont Môn học: \@rname \\}
    
    \vspace{1.5cm}
    
    {\fontsize{18}{22}\selectfont \textbf{\@tname} \\}
    
    \vfill
    \vfill
    
    \begin{minipage}{0.7\textwidth}
        {\fontsize{13}{16}\selectfont
        \begin{tabular}{ll}
            \textbf{Sinh viên thực hiện:}  & \begin{tabular}[t]{@{}l@{}} \@stuname \end{tabular} \\
            \textbf{Chuyên ngành:}         & \@sMajor
        \end{tabular}
        }
    \end{minipage}
    
    \vfill
    
    {\fontsize{13}{14}\selectfont \textbf{Hà Nội, \@ttime} \\}
\end{center}
\end{smashminipage}
}


